# Session token is injected by the macOS app.
LOCAL_AI_SESSION_TOKEN=replace-me

# Override default data path if needed.
LOCAL_AI_DATA_DIR=./data

# Optional MLX model paths used by startup profile.
LOCAL_AI_MODEL_FAST=
LOCAL_AI_MODEL_RECOMMENDED=
LOCAL_AI_MODEL_DEEP=

# External providers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
